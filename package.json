{
  "scripts": {
    "build": "npm run build:code && npm run build:css && npm run build:db",
    "build:clean": "node ./utils/packs.mjs package clean",
    "build:code": "rollup dnd5e.mjs -f es -o dnd5e-compiled.mjs -p node-resolve -m --sourcemapFile dnd5e.mjs",
    "build:css": "lessc less/dnd5e.less dnd5e.css --source-map",
    "build:db": "node ./utils/packs.mjs package pack",
    "build:json": "node ./utils/packs.mjs package unpack",
    "build:source": "node ./utils/packs.mjs package unpack",
    "compile": "npm run build:db",
    "dist": "npm run package:n5eb",
    "package:n5eb": "node ./utils/package-n5eb.mjs",
    "extract": "npm run build:source",
    "audit:automation": "node ./utils/audit-automation.mjs",
    "adversary:normalize": "node ./utils/normalize-adversary-packs.mjs",
    "adversary:normalize:dry": "node ./utils/normalize-adversary-packs.mjs --dry-run",
    "summon:normalize": "node ./utils/normalize-summon-packs.mjs",
    "summon:normalize:dry": "node ./utils/normalize-summon-packs.mjs --dry-run",
    "import:old-compendiums": "node ./utils/import-old-n5eb-compendiums.mjs",
    "optimize:assets": "node ./utils/optimize-n5eb-assets.mjs",
    "lint": "eslint --ext .mjs --ignore-path .gitignore ./",
    "lint:fix": "eslint --ext .mjs --ignore-path .gitignore ./ --fix",
    "postinstall": "npm run build:css && npm run build:db",
    "watch": "less-watch-compiler less/ ./ dnd5e.less --source-map"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.22.15",
    "@foundryvtt/foundryvtt-cli": "^1.0.0-rc.4",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "eslint-plugin-jsdoc": "^46.5.0",
    "fancy-log": "^2.0.0",
    "js-yaml": "^4.1.0",
    "less": "^4.2.0",
    "less-watch-compiler": "^1.16.3",
    "rollup": "^3.29.5",
    "sharp": "^0.34.5",
    "yargs": "^17.7.2"
  }
}
