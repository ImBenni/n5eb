    "dae": {
      "macro": {
        "name": "Abberation Passive",
        "img": "icons/creatures/tentacles/tentacle-eyes-yellow-pink.webp",
        "type": "script",
        "scope": "global",
        "command": "const version = \"1.0.0\";\ntry {\n  const lastArg = args[args.length - 1];\n\n  // Ensure the options exist and prevent the macro from re-triggering during update loops\n  lastArg.options = lastArg.options || {};\n  if (lastArg.options.onUpdateCalled) return;\n\n  // Get the actor from the arguments\n  const actor = game.actors.get(lastArg.actorId);\n  if (!actor) {\n    ui.notifications.error(\"Actor not found for the macro.\");\n    return;\n  }\n\n  // Ensure the actor is an adversary\n  if (actor.system.details?.npcType !== \"adversary\") {\n    ui.notifications.error(\"This macro only applies to adversary creatures.\");\n    return;\n  }\n\n  // Retrieve the rank of the adversary\n  const rank = actor.system.details.rank?.toLowerCase();\n  if (!rank) {\n    ui.notifications.error(\"Rank not found for this adversary.\");\n    return;\n  }\n\n  // Define Tenacity Dice by rank\n  const tenacityByRank = {\n    drank: 1,\n    crank: 2,\n    brank: 3,\n    arank: 4,\n    srank: 5,\n  };\n\n  const baseTenacityDice = tenacityByRank[rank] || 0;\n  const tenacityDice = baseTenacityDice * 3;\n\n  // Set the base tenacity and additional tenacity gain flag\n  await actor.setFlag(\"n5eb\", \"aberrationTenacityDice\", tenacityDice);\n\n  ui.notifications.info(`Aberration passive applied: ${tenacityDice} Tenacity Dice, with +3 gain each turn.`);\n} catch (err) {\n  console.error(`Aberration Passive Macro ${version}`, err);\n}",
        "author": "R0hw7EUsG7OzIhgn",
        "ownership": {
          "default": 3
        },
