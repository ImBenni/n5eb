  "system": {
    "description": {
      "value": "<p><span style=\"font-family:'Trebuchet MS'\">This Adversary can spend its Elite Action and 1 Tenacity die to raise its Draconic Stage by 1; </span></p><ul><li><p><span style=\"font-family:'Trebuchet MS'\">Stage 1: Increase AC by +1, Unarmed Damage die by +1. </span></p></li><li><p><span style=\"font-family:'Trebuchet MS'\">Stage 2: Ryu Hijutsu damage die increased by current Draconic Stage. </span></p></li><li><p><span style=\"font-family:'Trebuchet MS'\">Stage 3: Unarmed attacks gain Reach 2, Ryu Hijutsu cannot be dispelled by jutsu of equal or lower rank. </span></p></li><li><p><span style=\"font-family:'Trebuchet MS'\">Stage 4: Increase AC by +1, Unarmed Damage die by +1. </span></p></li><li><p><span style=\"font-family:'Trebuchet MS'\">Stage 5: This Adversary cannot lose concentration of Ryu Hijutsu.</span></p></li></ul>",
