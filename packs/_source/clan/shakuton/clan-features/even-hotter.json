    "itemacro": {
      "macro": {
        "command": "// Macro: Extra Fire Damage for Burned Condition\n\n// Ensure you have the DAE, Midi-QOL, and DIME modules installed and active.\n\nconst actor = game.user.character; // or you can specify the target actor\nconst token = actor?.token;\nconst burnedEffect = token.actor.effects.find(e => e.data.label === \"Burned\");\n\nif (burnedEffect && args[0].damageType === \"fire\") {\n    const extraDamage = new Roll(\"4d4\").roll().total;\n    \n    // Apply the extra damage\n    await MidiQOL.applyTokenDamage(\n        [{damage: extraDamage, type: \"fire\"}], \n        extraDamage, \n        new Set([token]), \n        null, \n        new Set()\n    );\n    \n    // Optional: Add a chat message for clarity\n    ChatMessage.create({\n        content: `${actor.name} suffers an additional ${extraDamage} fire damage due to the Burned condition!`\n    });\n}",
        "name": "Even Hotter",
        "img": "icons/magic/fire/elemental-fire-flying.webp",
