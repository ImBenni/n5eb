    "description": {
      "value": "<p><span id=\"page69R_mcid22\" class=\"markedContent\"><span dir=\"ltr\">N</span><span dir=\"ltr\">INJUTSU</span></span><span id=\"page69R_mcid23\" class=\"markedContent\"><br /><span dir=\"ltr\">Ninjutsu save DC</span> <span dir=\"ltr\">= 8 + your proficie</span><span dir=\"ltr\">ncy bonus + your </span><span dir=\"ltr\">Intelligence modifier.</span></span></p>\n<p><span id=\"page69R_mcid24\" class=\"markedContent\"><span dir=\"ltr\">Ninjutsu attack modifier</span> <span dir=\"ltr\">= your proficiency bonus + </span><span dir=\"ltr\">your Intelligence modifier.</span></span></p>\n<p><span id=\"page69R_mcid25\" class=\"markedContent\"><br /><span dir=\"ltr\">G</span><span dir=\"ltr\">ENJUTSU</span></span><span id=\"page69R_mcid26\" class=\"markedContent\"><br /><span dir=\"ltr\">Genjutsu save DC</span> <span dir=\"ltr\">= 8 + your proficiency bonus + your </span><span dir=\"ltr\">Wisdom modifier.</span></span></p>\n<p><span id=\"page69R_mcid27\" class=\"markedContent\"><span dir=\"ltr\">Genjutsu attack modifier</span> <span dir=\"ltr\">= your proficiency bonus + </span><span dir=\"ltr\">your Wis</span><span dir=\"ltr\">dom modifier.</span></span></p>\n<p><span id=\"page69R_mcid28\" class=\"markedContent\"><br /><span dir=\"ltr\">T</span><span dir=\"ltr\">AIJUTSU</span></span><span id=\"page69R_mcid29\" class=\"markedContent\"><br /><span dir=\"ltr\">Taijutsu save DC</span> <span dir=\"ltr\">= 8 + your proficiency bonus + your </span><span dir=\"ltr\">Strength modifier.</span></span></p>\n<p><span id=\"page69R_mcid30\" class=\"markedContent\"><span dir=\"ltr\">Taijutsu attack modifier</span> <span dir=\"ltr\">= your proficiency bonus + your </span><span dir=\"ltr\">Strength modifier.</span></span></p>",
