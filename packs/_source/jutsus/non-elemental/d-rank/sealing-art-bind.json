          "mode": 2,
          "value": "turn=start, \nlabel=Sealed,\ndamageBeforeSave=true,\nactionSave=dialog,\nsaveRemove=true,\nsaveDC=15,\nchatFlavor=MY CHAKRA ITS GONE,\nrollType=skill,\nsaveAbility=nin|ill,",
