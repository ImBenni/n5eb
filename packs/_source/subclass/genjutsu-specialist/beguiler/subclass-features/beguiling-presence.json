    "dae": {
      "macro": {
        "name": "Beguiling Presence",
        "img": "icons/magic/control/silhouette-aura-energy.webp",
        "type": "script",
        "scope": "global",
        "command": "const version = \"1.0.0\";\ntry {\n  const lastArg = args[args.length - 1];\n  const actor = game.actors.get(lastArg.actorId);\n\n  if (!actor) {\n    ui.notifications.error(\"Actor not found for the macro.\");\n    return;\n  }\n\n  // Ensure the actor is of the appropriate class\n  const subclass = actor.system.details.subclass;\n  if (!subclass || subclass !== \"YourSubclassIdentifier\") { // Replace with actual subclass identifier\n    ui.notifications.error(\"This macro can only be used with the specific subclass.\");\n    return;\n  }\n\n  // Get the actor's level\n  const level = actor.system.details.level || 1;\n\n  // Calculate the bonus based on the level\n  let bonus = 0;\n  if (level >= 2 && level < 10) {\n    bonus = 1;\n  } else if (level >= 10 && level < 19) {\n    bonus = 2;\n  } else if (level >= 19) {\n    bonus = 3;\n  }\n\n  // Set the flag for the visual keyword bonus\n  await actor.setFlag(\"n5eb\", \"genjutsuVisualDCBonus\", bonus);\n\n  ui.notifications.info(`Visual keyword Genjutsu DC bonus set to +${bonus} for ${actor.name} at level ${level}.`);\n} catch (err) {\n  console.error(`Visual Keyword DC Bonus Macro ${version}`, err);\n}",
        "author": "R0hw7EUsG7OzIhgn",
        "ownership": {
          "default": 3
        },
