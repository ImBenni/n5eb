    "dae": {
      "macro": {
        "name": "Caster",
        "img": "icons/magic/sonic/explosion-shock-wave-teal.webp",
        "type": "script",
        "scope": "global",
        "command": "const version = \"1.0.0\";\ntry {\n  const lastArg = args[args.length - 1];\n\n  const actor = game.actors.get(lastArg.actorId);\n  if (!actor) {\n    ui.notifications.error(\"Actor not found for the macro.\");\n    return;\n  }\n\n  if (actor.system.details?.npcType !== \"summon\") {\n    ui.notifications.error(\"This macro only applies to summoned creatures.\");\n    return;\n  }\n\n  const rank = actor.system.details.rank?.toLowerCase();\n  if (!rank) {\n    ui.notifications.error(\"Rank not found for this summon.\");\n    return;\n  }\n\n  const jutsuSlotsByRank = {\n    drank: 1,\n    crank: 1,\n    brank: 2,\n    arank: 2,\n    srank: 3,\n  };\n\n  const additionalJutsuSlots = jutsuSlotsByRank[rank] || 0;\n  await actor.setFlag(\"n5eb\", \"summonJutsuSlotBonus\", additionalJutsuSlots);\n\n  ui.notifications.info(`Jutsu Slots bonus set to +${additionalJutsuSlots} for rank ${rank.toUpperCase()}`);\n  \n} catch (err) {\n  console.error(`Caster Macro ${version}`, err);\n}",
        "author": "R0hw7EUsG7OzIhgn",
