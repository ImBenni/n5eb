    "dae": {
      "macro": {
        "name": "Supporter",
        "img": "icons/magic/life/ankh-shadow-green.webp",
        "type": "script",
        "scope": "global",
        "command": "const version = \"1.0.0\";\ntry {\n  const lastArg = args[args.length - 1];\n\n  // Get the actor\n  const actor = game.actors.get(lastArg.actorId);\n  if (!actor) {\n    ui.notifications.error(\"Actor not found for the macro.\");\n    return;\n  }\n\n  // Check if the actor is a summon\n  if (actor.system.details?.npcType !== \"summon\") {\n    ui.notifications.error(\"This macro only applies to summoned creatures.\");\n    return;\n  }\n\n  // Retrieve the rank of the summon\n  const rank = actor.system.details.rank?.toLowerCase();\n  if (!rank) {\n    ui.notifications.error(\"Rank not found for this summon.\");\n    return;\n  }\n\n  // Define the healing/temporary hit points bonus based on the rank\n  const healingBonusByRank = {\n    drank: 1,\n    crank: 1,\n    brank: 2,\n    arank: 2,\n    srank: 3,\n  };\n\n  // Get the additional healing bonus dice\n  const additionalHealingBonus = healingBonusByRank[rank] || 0;\n\n  // Store the healing bonus in the actor flags\n  await actor.setFlag(\"n5eb\", \"summonHealingBonus\", additionalHealingBonus);\n\n  ui.notifications.info(`Healing/Temp HP bonus dice set to +${additionalHealingBonus} for rank ${rank.toUpperCase()}`);\n\n} catch (err) {\n  console.error(`Support Macro ${version}`, err);\n}",
        "author": "R0hw7EUsG7OzIhgn",
        "ownership": {
          "default": 3
        },
