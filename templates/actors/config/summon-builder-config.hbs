<section class="npc-builder adversary-builder summon-builder flexcol" data-builder-mode="summon">
    <nav class="npc-builder-modes" aria-label="{{ localize 'N5EB.NPCBuilder.Mode' }}">
        <button type="button" data-action="switchBuilderMode" data-mode="adversary" aria-pressed="false">
            <i class="fa-solid fa-user-ninja" inert></i>
            <span>{{ localize "N5EB.NPCBuilder.AdversaryMode" }}</span>
        </button>
        <button type="button" data-action="switchBuilderMode" data-mode="summon" class="active"
                aria-pressed="true">
            <i class="fa-solid fa-paw" inert></i>
            <span>{{ localize "N5EB.NPCBuilder.SummonMode" }}</span>
        </button>
    </nav>
    <div class="adversary-builder-layout">
        <aside class="adversary-blueprint">
            <div class="adversary-identity-card summon-identity-card">
                <img src="{{ actor.img }}" alt="{{ actor.name }}">
                <div class="identity-copy">
                    <span class="eyebrow">{{ localize "N5EB.Summon.Builder.Blueprint" }}</span>
                    <strong>{{ actor.name }}</strong>
                    <div class="identity-strip">
                        <span class="rank-badge" data-identity-rank>{{ identity.rank.abbreviation }}</span>
                        <span class="identity-chip" data-identity-category>{{ identity.category.label }}</span>
                        <span class="identity-chip" data-identity-role>{{ identity.role.label }}</span>
                        <span class="identity-chip" data-identity-tribe {{#unless identity.tribe}}hidden{{/unless}}>
                            {{ identity.tribe.label }}
                        </span>
                        <span class="identity-chip" data-identity-variant {{#unless identity.variant}}hidden{{/unless}}>
                            {{ identity.variant.label }}
                        </span>
                        <span class="identity-chip" data-identity-type {{#unless identity.summonType}}hidden{{/unless}}>
                            {{ identity.summonType.label }}
                        </span>
                    </div>
                </div>
            </div>

            <fieldset class="card adversary-card compact">
                <legend>{{ localize "N5EB.Summon.Builder.Metadata" }}</legend>

                <div class="form-group">
                    <label>{{ localize "N5EB.Summon.Level" }}</label>
                    <div class="form-fields">
                        <input type="number" name="summon.level" value="{{ source.level }}" min="1" max="30" step="1">
                    </div>
                </div>

                <div class="form-group">
                    <label>{{ localize "N5EB.Summon.Rank.Label" }}</label>
                    <div class="form-fields">
                        <select name="summon.rank">
                            {{ selectOptions CONFIG.summonRanks selected=source.rank labelAttr="label" }}
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>{{ localize "N5EB.Summon.Category.Label" }}</label>
                    <div class="form-fields">
                        <select name="summon.category">
                            {{ selectOptions CONFIG.summonCategories selected=source.category labelAttr="label" }}
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>{{ localize "N5EB.Summon.Tribe.Label" }}</label>
                    <div class="form-fields">
                        <span class="summon-tribe-readout">
                            {{#if selectedTribe}}
                            {{ selectedTribe.label }}
                            {{else}}
                            {{ localize "N5EB.Summon.Builder.NoTribeSelected" }}
                            {{/if}}
                        </span>
                    </div>
                </div>
                <input type="hidden" name="summon.tribe" value="{{ source.tribe }}">

                <div class="form-group">
                    <label>{{ localize "N5EB.Summon.Variant" }}</label>
                    <div class="form-fields">
                        <input type="text" name="summon.variant" value="{{ source.variant }}">
                    </div>
                </div>

                <div class="form-group">
                    <label>{{ localize "N5EB.Summon.Role.Label" }}</label>
                    <div class="form-fields">
                        <select name="summon.role">
                            {{ selectOptions CONFIG.summonRoles selected=source.role labelAttr="label" }}
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>{{ localize "N5EB.Summon.Type.Label" }}</label>
                    <div class="form-fields">
                        <select name="summon.summonType">
                            {{ selectOptions summonTypeOptions selected=source.summonType labelAttr="label" }}
                        </select>
                    </div>
                </div>

                <input type="hidden" name="summon.migrated" value="{{ source.migrated }}">
                <input type="hidden" name="summon.sourceUuid" value="{{ source.sourceUuid }}">
            </fieldset>

            <fieldset class="card adversary-card summon-library-card">
                <legend>{{ localize "N5EB.Summon.Builder.Library" }}</legend>
                <div class="summon-selected-definition {{#unless selectedTribe}}empty{{/unless}}">
                    <img src="{{#if selectedTribe}}{{ selectedTribe.img }}{{else}}icons/svg/book.svg{{/if}}" alt="">
                    <div>
                        <span class="eyebrow">{{ localize "N5EB.Summon.Builder.SelectedTribe" }}</span>
                        <strong>
                            {{#if selectedTribe}}
                            {{ selectedTribe.label }}
                            {{else}}
                            {{ localize "N5EB.Summon.Builder.NoTribeSelected" }}
                            {{/if}}
                        </strong>
                        <small>
                            {{#if selectedTribe}}
                            {{ selectedTribe.sourceLabel }}
                            {{else}}
                            {{ localize "N5EB.Summon.Builder.TribeAdvancementHint" }}
                            {{/if}}
                        </small>
                    </div>
                    {{#if selectedTribe.uuid}}
                    <button type="button" class="unbutton" data-action="openDefinition" data-uuid="{{ selectedTribe.uuid }}"
                            data-tooltip="N5EB.Summon.Builder.OpenTribe"
                            aria-label="{{ localize 'N5EB.Summon.Builder.OpenTribe' }}">
                        <i class="fa-solid fa-arrow-up-right-from-square" inert></i>
                    </button>
                    {{/if}}
                </div>
                <div class="summon-library-actions">
                    <button type="button" data-action="selectTribe">
                        <i class="fa-solid fa-book-open-reader" inert></i>
                        <span>{{ localize "N5EB.Summon.Builder.SelectTribe" }}</span>
                    </button>
                    <button type="button" data-action="createDefinition" data-kind="tribe">
                        <i class="fa-solid fa-plus" inert></i>
                        <span>{{ localize "N5EB.Summon.Builder.CreateTribe" }}</span>
                    </button>
                    <button type="button" data-action="createDefinition" data-kind="type">
                        <i class="fa-solid fa-plus" inert></i>
                        <span>{{ localize "N5EB.Summon.Builder.CreateType" }}</span>
                    </button>
                </div>
            </fieldset>

            <fieldset class="card adversary-card summon-library-card" data-inuzuka-breed-card
                      {{#unless showInuzukaBreed}}hidden{{/unless}}>
                <legend>{{ localize "N5EB.Summon.Builder.InuzukaBreed" }}</legend>
                <div class="summon-selected-definition {{#unless selectedBreed}}empty{{/unless}}">
                    <img src="{{#if selectedBreed}}{{ selectedBreed.img }}{{else}}systems/n5eb/icons/svg/actors/npc.svg{{/if}}" alt="">
                    <div>
                        <span class="eyebrow">{{ localize "N5EB.Summon.Builder.SelectedBreed" }}</span>
                        <strong>
                            {{#if selectedBreed}}
                            {{ selectedBreed.label }}
                            {{else}}
                            {{ localize "N5EB.Summon.Builder.NoBreedSelected" }}
                            {{/if}}
                        </strong>
                        <small>
                            {{#if selectedBreed}}
                            {{ selectedBreed.sourceLabel }}
                            {{else}}
                            {{ localize "N5EB.Summon.Builder.BreedAdvancementHint" }}
                            {{/if}}
                        </small>
                    </div>
                    {{#if selectedBreed.uuid}}
                    <button type="button" class="unbutton" data-action="openDefinition" data-uuid="{{ selectedBreed.uuid }}"
                            data-tooltip="N5EB.Summon.Builder.OpenBreed"
                            aria-label="{{ localize 'N5EB.Summon.Builder.OpenBreed' }}">
                        <i class="fa-solid fa-arrow-up-right-from-square" inert></i>
                    </button>
                    {{/if}}
                </div>
                <div class="summon-library-actions one-action">
                    <button type="button" data-action="selectBreed">
                        <i class="fa-solid fa-dog" inert></i>
                        <span>{{ localize "N5EB.Summon.Builder.SelectBreed" }}</span>
                    </button>
                </div>
            </fieldset>

            <fieldset class="card adversary-card summary-card">
                <legend>{{ localize "N5EB.Summon.Builder.RulesSummary" }}</legend>
                <dl class="adversary-summary-grid">
                    <div>
                        <dt>{{ localize "N5EB.Summon.Builder.JutsuSlots" }}</dt>
                        <dd data-summary-slots>{{ summary.jutsuSlots }}</dd>
                    </div>
                    <div>
                        <dt>{{ localize "N5EB.Summon.Toughness" }}</dt>
                        <dd data-summary-toughness>{{ summary.toughness }}</dd>
                    </div>
                    <div>
                        <dt>{{ localize "N5EB.Summon.DefenseAbility" }}</dt>
                        <dd data-summary-defense>{{ summary.defenseAbilityLabel }}</dd>
                    </div>
                    <div>
                        <dt>{{ localize "N5EB.Summon.JutsuAbility" }}</dt>
                        <dd data-summary-jutsu>{{ summary.jutsuAbilityLabel }}</dd>
                    </div>
                </dl>
            </fieldset>

            <fieldset class="card adversary-card resources-card">
                <legend>{{ localize "N5EB.Summon.Builder.Defaults" }}</legend>
                <div class="adversary-resource-grid">
                    <label>
                        <span>{{ localize "N5EB.Summon.Toughness" }}</span>
                        <input type="number" name="summon.toughness" value="{{ source.toughness }}" min="0" step="1">
                    </label>
                    <label>
                        <span>{{ localize "N5EB.Summon.DefenseAbility" }}</span>
                        <select name="summon.defenseAbility">
                            {{ selectOptions CONFIG.abilities selected=source.defenseAbility labelAttr="label" blank=(localize "N5EB.None") }}
                        </select>
                    </label>
                    <label>
                        <span>{{ localize "N5EB.Summon.JutsuAbility" }}</span>
                        <select name="summon.jutsuAbility">
                            {{ selectOptions CONFIG.abilities selected=source.jutsuAbility labelAttr="label" blank=(localize "N5EB.None") }}
                        </select>
                    </label>
                </div>
                <button type="button" class="apply-defaults" data-action="applyDefaults">
                    <i class="fa-solid fa-wand-magic-sparkles" inert></i>
                    <span>{{ localize "N5EB.Summon.Builder.ApplyDefaults" }}</span>
                </button>
            </fieldset>

            <fieldset class="card adversary-card warnings-card" {{#unless warnings.length}}hidden{{/unless}}>
                <legend>{{ localize "Warnings" }}</legend>
                {{#each warnings}}
                <p>{{ this }}</p>
                {{/each}}
            </fieldset>
        </aside>

        <section class="adversary-content-card">
            <nav class="adversary-content-tabs summon-content-tabs" aria-label="{{ localize 'N5EB.Summon.Builder.Content' }}">
                {{#each contentTabs}}
                <button type="button" data-action="switchTab" data-tab="{{ id }}" class="{{#if active}}active{{/if}}"
                        aria-pressed="{{ active }}">
                    <span>{{ localize label }}</span>
                    {{#if (eq id "selected")}}
                    <strong data-selected-count>0</strong>
                    {{else}}
                    <strong>{{ count }}</strong>
                    {{/if}}
                </button>
                {{/each}}
            </nav>

            <div class="adversary-preview" data-preview data-uuid="{{ preview.uuid }}">
                <img src="{{ preview.img }}" alt="{{ preview.name }}" data-preview-image>
                <div class="preview-copy">
                    <span class="eyebrow">{{ localize "N5EB.Summon.Builder.Preview" }}</span>
                    <strong data-preview-name>{{ preview.name }}</strong>
                    <div class="preview-tags">
                        <span data-preview-type>{{ preview.typeLabel }}</span>
                        <span data-preview-rank>{{ preview.rankLabel }}</span>
                        <span data-preview-kind>{{ preview.kindLabel }}</span>
                        <span data-preview-pack>{{ preview.pack }}</span>
                    </div>
                    <div class="preview-description" data-preview-description>
                        {{#if preview.description}}
                        {{{ preview.description }}}
                        {{else}}
                        <p>{{ localize "N5EB.Summon.Builder.NoPreview" }}</p>
                        {{/if}}
                    </div>
                </div>
                <button type="button" class="unbutton preview-open" data-preview-open
                        data-tooltip="N5EB.Summon.Builder.OpenPreview"
                        aria-label="{{ localize 'N5EB.Summon.Builder.OpenPreview' }}">
                    <i class="fa-solid fa-arrow-up-right-from-square" inert></i>
                </button>
            </div>

            <div class="adversary-content-panel" data-content-panel="features">
                {{> ".filters" ranks=filterRanks kinds=featureKinds categories=featureCategories sources=featurePacks tribes=tribeFilters types=typeFilters }}
                {{#if suggestions.features.length}}
                <div class="adversary-suggestions">
                    {{#each suggestions.features}}
                    {{> ".suggestion" }}
                    {{/each}}
                </div>
                {{/if}}
                <p class="empty-filter" data-filter-empty hidden>{{ localize "N5EB.Summon.Builder.NoSuggestions" }}</p>
            </div>

            <div class="adversary-content-panel" data-content-panel="weapons" hidden>
                {{> ".filters" ranks=filterRanks kinds=weaponKinds categories=weaponCategories sources=weaponPacks tribes=tribeFilters types=typeFilters }}
                {{#if suggestions.weapons.length}}
                <div class="adversary-suggestions">
                    {{#each suggestions.weapons}}
                    {{> ".suggestion" }}
                    {{/each}}
                </div>
                {{/if}}
                <p class="empty-filter" data-filter-empty hidden>{{ localize "N5EB.Summon.Builder.NoSuggestions" }}</p>
            </div>

            <div class="adversary-content-panel" data-content-panel="jutsu" hidden>
                {{> ".filters" ranks=filterRanks kinds=jutsuKinds categories=jutsuCategories sources=jutsuPacks tribes=tribeFilters types=typeFilters }}
                {{#if suggestions.jutsu.length}}
                <div class="adversary-suggestions">
                    {{#each suggestions.jutsu}}
                    {{> ".suggestion" }}
                    {{/each}}
                </div>
                {{/if}}
                <p class="empty-filter" data-filter-empty hidden>{{ localize "N5EB.Summon.Builder.NoSuggestions" }}</p>
            </div>

            <div class="adversary-content-panel selected-panel" data-content-panel="selected" hidden>
                <div class="selected-heading">
                    <strong>{{ localize "N5EB.Summon.Builder.Selected" }}</strong>
                    <span><span data-selected-count>0</span> {{ localize "N5EB.Summon.Builder.SelectedSuffix" }}</span>
                </div>
                <p class="empty-filter" data-selected-empty>{{ localize "N5EB.Summon.Builder.NoneSelected" }}</p>
                <ol class="adversary-selected-list unlist" data-selected-list></ol>
            </div>
        </section>
    </div>

    <footer class="form-footer">
        <button type="button" data-action="save">
            <i class="fa-solid fa-floppy-disk" inert></i>
            <span>{{ localize "SETTINGS.Save" }}</span>
        </button>
        <button type="button" data-action="addSelected">
            <i class="fa-solid fa-plus" inert></i>
            <span>{{ localize "N5EB.Summon.Builder.AddSelected" }}</span>
            <strong data-selected-count>0</strong>
        </button>
    </footer>
</section>

{{#*inline ".filters"}}
<div class="adversary-filter-bar">
    <label class="search">
        <i class="fa-solid fa-magnifying-glass" inert></i>
        <input type="search" class="adversary-filter" data-filter="search"
               placeholder="{{ localize 'N5EB.Summon.Builder.Search' }}">
    </label>
    <select class="adversary-filter" data-filter="rank" aria-label="{{ localize 'N5EB.Summon.Rank.Label' }}">
        {{#each ranks}}
        <option value="{{ value }}">{{ label }}</option>
        {{/each}}
    </select>
    <select class="adversary-filter" data-filter="kind" aria-label="{{ localize 'N5EB.Summon.Builder.Type' }}">
        {{#each kinds}}
        <option value="{{ value }}">{{ label }}</option>
        {{/each}}
    </select>
    {{#if categories}}
    <select class="adversary-filter" data-filter="category" aria-label="{{ localize 'N5EB.Summon.Builder.Category' }}">
        {{#each categories}}
        <option value="{{ value }}">{{ label }}</option>
        {{/each}}
    </select>
    {{/if}}
    <select class="adversary-filter" data-filter="source" aria-label="{{ localize 'N5EB.Summon.Builder.Source' }}">
        {{#each sources}}
        <option value="{{ value }}">{{ label }}</option>
        {{/each}}
    </select>
    {{#if tribes}}
    <select class="adversary-filter" data-filter="tribe" aria-label="{{ localize 'N5EB.Summon.Tribe.Label' }}">
        {{#each tribes}}
        <option value="{{ value }}">{{ label }}</option>
        {{/each}}
    </select>
    {{/if}}
    {{#if types}}
    <select class="adversary-filter" data-filter="summonType" aria-label="{{ localize 'N5EB.Summon.Type.Label' }}">
        {{#each types}}
        <option value="{{ value }}">{{ label }}</option>
        {{/each}}
    </select>
    {{/if}}
</div>
{{/inline}}

{{#*inline ".suggestion"}}
<label class="adversary-suggestion {{#if disabled}}is-added{{/if}}"
       data-uuid="{{ uuid }}"
       data-name="{{ name }}"
       data-img="{{ img }}"
       data-rank="{{ rank }}"
       data-rank-label="{{ rankLabel }}"
       data-kind="{{ kind }}"
       data-kind-label="{{ kindLabel }}"
       data-category="{{ category }}"
       data-category-label="{{ categoryLabel }}"
       data-type-label="{{ typeLabel }}"
       data-pack="{{ packKey }}"
       data-pack-label="{{ pack }}"
       data-source="{{ sourceKey }}"
       data-source-label="{{ sourceLabel }}"
       data-tribes="{{ tribes }}"
       data-types="{{ types }}"
       data-roles="{{ roles }}"
       data-ranks="{{ ranks }}"
       data-search="{{ search }}">
    <input type="checkbox" name="itemUuids" value="{{ uuid }}" {{ disabled disabled }}>
    <img src="{{ img }}" alt="">
    <span class="name">{{ name }}</span>
    <span class="meta">
        {{#if rankLabel}}<span>{{ rankLabel }}</span>{{/if}}
        {{#if kindLabel}}<span>{{ kindLabel }}</span>{{/if}}
        <span>{{ pack }}</span>
    </span>
    {{#if disabled}}
    <span class="status">{{ localize "N5EB.Summon.Builder.Added" }}</span>
    {{/if}}
    <template>{{{ description }}}</template>
</label>
{{/inline}}
