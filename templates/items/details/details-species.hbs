<fieldset>
    <legend>{{ localize "DND5E.ItemSpeciesDetails" }}</legend>

    {{!-- Identifier --}}
    {{ formField fields.identifier value=source.identifier placeholder=item.identifier hint="DND5E.IdentifierError"
                 localize=true rootId=partId }}

    {{!-- Origin --}}
    {{ formField fields.origin.fields.land value=source.origin.land choices=CONFIG.clanOriginLands labelAttr="label"
                 blank="N5EB.Clan.Origin.Unspecified" localize=true rootId=partId }}
    {{ formField fields.origin.fields.village value=source.origin.village choices=CONFIG.clanOriginVillages
                 labelAttr="label" blank="N5EB.Clan.Origin.Unspecified" localize=true rootId=partId }}
</fieldset>
