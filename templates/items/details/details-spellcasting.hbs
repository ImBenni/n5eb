<fieldset>
    <legend>{{ localize "N5EB.JUTSU.CastingAbilities" }}</legend>

    {{ formField fields.jutsu.fields.abilities.fields.ninjutsu value=source.jutsu.abilities.ninjutsu
                 choices=CONFIG.abilities labelAttr="label" localize=true rootId=partId }}

    {{ formField fields.jutsu.fields.abilities.fields.genjutsu value=source.jutsu.abilities.genjutsu
                 choices=CONFIG.abilities labelAttr="label" localize=true rootId=partId }}

    {{ formField fields.jutsu.fields.abilities.fields.taijutsu value=source.jutsu.abilities.taijutsu
                 choices=CONFIG.abilities labelAttr="label" localize=true rootId=partId }}

    {{!-- Legacy spellcasting compatibility data --}}
    <input type="hidden" name="system.spellcasting.progression" value="{{ source.spellcasting.progression }}">
    <input type="hidden" name="system.spellcasting.ability" value="{{ source.spellcasting.ability }}">
    <input type="hidden" name="system.spellcasting.preparation.formula"
           value="{{ source.spellcasting.preparation.formula }}">

</fieldset>
